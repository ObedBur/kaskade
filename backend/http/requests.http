### ============================================================
### VARIABLES GLOBALES & CAPTURE
### ============================================================
@baseUrl = http://localhost:4000/api/v1
@clientToken = {{loginClient.response.body.tokens.accessToken}}
@adminToken = {{loginAdmin.response.body.tokens.accessToken}}
@providerToken = {{loginProvider.response.body.tokens.accessToken}}

### ------------------------------------------------------------
### AUTH PRE-REQUIS
### ------------------------------------------------------------

# @name loginClient
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "obedburindi@gmail.com",
  "password": "password123"
}

###

# @name loginAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "kaskade@gmail.com",
  "password": "password123"
}

###

# @name loginProvider
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "provider@gmail.com",
  "password": "password123"
}


### ------------------------------------------------------------
### 1. SERVICES (ADMIN)
### ------------------------------------------------------------

# @name listServices
GET {{baseUrl}}/services
Authorization: Bearer {{clientToken}}

###

# @name createService
POST {{baseUrl}}/services
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Plomberie d'Urgence",
  "category": "PLOMBERIE",
  "description": "Réparation de fuites et débouchage rapide.",
  "price": 25000
}

@serviceId = {{createService.response.body.id}}


### ------------------------------------------------------------
### 2. REQUEST WORKFLOW (CLIENT)
### ------------------------------------------------------------

# @name createRequest
POST {{baseUrl}}/requests
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "serviceId": "REPLACE_WITH_VALID_SERVICE_ID",
  "description": "Ma douche fuit au rez-de-chaussée.",
  "address": "123 Avenue de la Paix, Goma",
  "scheduledAt": "2026-05-10T14:00:00Z"
}

@requestId = {{createRequest.response.body.id}}

###

# @name getMyRequests
GET {{baseUrl}}/requests/my
Authorization: Bearer {{clientToken}}


### ------------------------------------------------------------
### 3. ADMIN ACTIONS (APPROVAL)
### ------------------------------------------------------------

# @name adminListRequests
GET {{baseUrl}}/admin/requests
Authorization: Bearer {{adminToken}}

###

# @name adminApproveRequest
PATCH {{baseUrl}}/admin/requests/{{requestId}}/approve
Authorization: Bearer {{adminToken}}


### ------------------------------------------------------------
### 4. PROVIDER ACTIONS
### ------------------------------------------------------------

# @name providerAvailableRequests
GET {{baseUrl}}/providers/available-requests
Authorization: Bearer {{providerToken}}

###

# @name providerAcceptRequest
PATCH {{baseUrl}}/providers/requests/{{requestId}}/accept
Authorization: Bearer {{providerToken}}


### ------------------------------------------------------------
### 5. COMPLETION & PAYMENTS
### ------------------------------------------------------------

# @name mockDeposit
PATCH {{baseUrl}}/requests/{{requestId}}/mock-deposit
Authorization: Bearer {{clientToken}}

###

# @name providerCompleteRequest
PATCH {{baseUrl}}/providers/requests/{{requestId}}/complete
Authorization: Bearer {{providerToken}}
