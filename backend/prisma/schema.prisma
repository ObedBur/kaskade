generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  fullName             String
  password             String
  role                 Role                  @default(CLIENT)
  createdAt            DateTime              @default(now())
  avatarUrl            String?
  bio                  String?
  deletedAt            DateTime?
  experience           String?
  isActive             Boolean               @default(true)
  isPremium            Boolean               @default(false)
  isVerified           Boolean               @default(false)
  metier               String?
  phone                String                @unique
  quartier             String
  refreshToken         String?
  status               Status                @default(DISPONIBLE)
  updatedAt            DateTime              @updatedAt
  notifications        Notification[]
  providerApplications ProviderApplication[]
  clientRequests       Request[]             @relation("ClientRequests")
  providerRequests     Request[]             @relation("ProviderRequests")
  services             Service[]             @relation("ServiceToUser")

  @@index([email])
  @@index([phone])
  @@index([quartier])
}

model Service {
  id                String         @id @default(uuid())
  name              String
  category          String
  description       String?
  price             Float?
  currency          String         @default("USD")
  isActive          Boolean        @default(true)
  imageKey          String?
  workingHoursStart String         @default("06:00")
  workingHoursEnd   String         @default("18:00")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  notifications     Notification[]
  requests          Request[]
  providers         User[]         @relation("ServiceToUser")

  @@index([category])
}

model Payment {
  id          String   @id @default(uuid())
  requestId   String
  clientId    String
  amount      Float
  currency    String   @default("USD")
  operator    String
  phoneNumber String
  mbiyoRef    String?  @unique
  status      String   @default("PENDING")
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  request     Request  @relation(fields: [requestId], references: [id])
}

model Request {
  id                String         @id @default(uuid())
  clientId          String
  serviceId         String
  providerId        String?
  description       String
  address           String
  scheduledAt       DateTime
  scheduleFrequency String?
  scheduleDay       String?
  scheduleTime      String?
  subscriptionEndsAt DateTime?
  subscriptionEndingNotifiedAt DateTime?
  subscriptionEndedAt DateTime?
  notes             String?
  price             Float?
  currency          String         @default("USD")
  acceptedAt        DateTime?
  status            RequestStatus  @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  notifications     Notification[]
  payments          Payment[]
  client            User           @relation("ClientRequests", fields: [clientId], references: [id])
  provider          User?          @relation("ProviderRequests", fields: [providerId], references: [id])
  service           Service        @relation(fields: [serviceId], references: [id])

  @@index([clientId])
  @@index([serviceId])
  @@index([providerId])
  @@index([status])
  @@index([subscriptionEndsAt])
}

model ProviderApplication {
  id            String         @id @default(uuid())
  userId        String
  motivation    String
  status        RequestStatus  @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
  user          User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Notification {
  id            String               @id @default(uuid())
  userId        String
  title         String
  message       String
  type          String
  isRead        Boolean              @default(false)
  requestId     String?
  serviceId     String?
  providerAppId String?
  createdAt     DateTime             @default(now())
  providerApp   ProviderApplication? @relation(fields: [providerAppId], references: [id])
  request       Request?             @relation(fields: [requestId], references: [id])
  service       Service?             @relation(fields: [serviceId], references: [id])
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([requestId])
  @@index([serviceId])
  @@index([providerAppId])
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum Status {
  DISPONIBLE
  EN_MISSION
  INDISPONIBLE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  ACCEPTED
  IN_PROGRESS
  AWAITING_FINAL
  COMPLETED
}
