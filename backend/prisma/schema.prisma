generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  fullName      String    
  phone         String    @unique 
  
  quartier      String    
  
  role          Role      @default(CLIENT)
  status        Status    @default(DISPONIBLE) 
  isPremium     Boolean   @default(false)    
  
  metier        String?   
  experience    String?   @db.Text 
  
  isVerified    Boolean   @default(false) 
  isActive      Boolean   @default(true)
  refreshToken  String?   
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([email])
  @@index([phone])
  @@index([quartier]) 
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum Status {
  DISPONIBLE    
  EN_MISSION    
  INDISPONIBLE  
}