# ==============================================================================
# VARIABLES D'ENVIRONNEMENT - KASKADE MONOREPO
# ==============================================================================

# ------------------------------------------------------------------------------
# BASE DE DONNÉES (POSTGRESQL)
# ------------------------------------------------------------------------------
# Lien de connexion à la base de données (ex: Render PostgreSQL, Neon, Supabase)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# ------------------------------------------------------------------------------
# BACKEND (NestJS)
# ------------------------------------------------------------------------------
PORT=4000
FRONTEND_URL="https://votre-frontend-vercel.vercel.app"
# URL publique du backend (pour les images /uploads en production)
API_PUBLIC_URL="https://votre-backend-render.onrender.com"

# Sécurité (JWT)
# Générez des chaînes aléatoires fortes pour la production (ex: openssl rand -base64 32)
JWT_ACCESS_SECRET="votre_secret_jwt_access"
JWT_REFRESH_SECRET="votre_secret_jwt_refresh"

# Emailing (Brevo)
BREVO_API_KEY="votre_cle_api_brevo"
MAIL_FROM_EMAIL="contact@kaskade.com"
MAIL_FROM_NAME="L'équipe Kaskade"

# Paiements (Mbiyo Pay — https://dashboard.mbiyo.africa/docs)
MBIYO_API_URL="https://dashboard.mbiyo.africa/api/v1"
MBIYO_SECRET_KEY="votre_cle_api_test_mbiyo"
MBIYO_WEBHOOK_SECRET="votre_secret_webhook_mbiyo"
MBIYO_WEBHOOK_URL="https://votre-backend-render.onrender.com/api/v1/payments/webhook/mbiyo"

# ------------------------------------------------------------------------------
# FRONTEND (Next.js)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="https://votre-backend-render.onrender.com/api/v1"
# URL de base pour les médias (images uploadées). Identique à API_PUBLIC_URL.
NEXT_PUBLIC_MEDIA_URL="https://votre-backend-render.onrender.com"
